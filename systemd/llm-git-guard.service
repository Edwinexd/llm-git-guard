[Unit]
Description=llm-git-guard: local git smart-HTTP proxy with safety validation
Documentation=https://github.com/Edwinexd/llm-git-guard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root
ExecStart=/usr/bin/python3 /opt/llm-git-guard/src/llm_git_guard/server.py
Restart=on-failure
RestartSec=3

Environment=LLMGG_REPOS_DIR=/var/lib/llm-git-guard/repos
Environment=LLMGG_HOOKS_DIR=/opt/llm-git-guard/hooks
Environment=LLMGG_CONFIG_DIR=/etc/llm-git-guard
Environment=LLMGG_SSH_KEY=/root/.ssh/id_ed25519
Environment=LLMGG_KNOWN_HOSTS=/root/.ssh/known_hosts
Environment=LLMGG_BIND=127.0.0.1
Environment=LLMGG_PORT=9419

# Modest hardening. The service needs network + write access to its data and
# ssh key, but nothing else.
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/var/lib/llm-git-guard
ProtectHome=read-only
PrivateTmp=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictSUIDSGID=true
LockPersonality=true

[Install]
WantedBy=multi-user.target
